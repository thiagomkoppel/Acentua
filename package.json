{
  "name": "acentua",
  "version": "0.1.0",
  "description": "Privacy-focused Chrome extension for restoring high-confidence Brazilian Portuguese accents.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node scripts/build.js",
    "format": "prettier --check .",
    "lint": "eslint .",
    "test": "npm run validate:dictionaries && npm run test:unit && npm run test:browser",
    "test:browser": "playwright test",
    "test:unit": "vitest run",
    "validate:dictionaries": "node scripts/validate-dictionaries.js",
    "expand:safe": "node scripts/expand-safe-dictionary.js",
    "expand:ambiguous": "node scripts/expand-ambiguous-dictionary.js",
    "import:ambiguous": "node scripts/import-ambiguous-dictionary.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@playwright/test": "^1.45.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "jsdom": "^24.0.0",
    "prettier": "^3.0.0",
    "vitest": "^4.1.10"
  }
}
